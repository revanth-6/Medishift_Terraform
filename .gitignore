# Local .terraform path (contains plugins and binaries)
**/.terraform/*

# .tfstate files (contains cleartext secrets and state)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude private variables containing credentials
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Exclude CLI config files
.terraformrc
terraform.rc

# Exclude locally generated archive binaries
*.zip
medishift.zip
